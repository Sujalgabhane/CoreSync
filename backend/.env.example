# ─── DATABASE ─────────────────────────────────────────────────────────────
# Local Docker dev (docker-compose up → postgres on 5432)
DATABASE_URL=postgresql://coresync:coresync_pass@localhost:5432/coresync

# Production Supabase (replace with your Supabase connection string)
# DATABASE_URL=postgresql://postgres:[YOUR-SUPABASE-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ─── REDIS ────────────────────────────────────────────────────────────────
# Local Docker dev
REDIS_URL=redis://localhost:6379

# Production Upstash (replace with your Upstash Redis URL)
# REDIS_URL=rediss://default:[YOUR-UPSTASH-TOKEN]@[YOUR-UPSTASH-HOST]:6380

# ─── JWT ──────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=coresync_access_secret_change_in_production_min_32_chars
JWT_REFRESH_SECRET=coresync_refresh_secret_change_in_production_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── EMAIL (SMTP) ─────────────────────────────────────────────────────────
# For local dev: leave blank → emails are only logged to console
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM="CoreSync <your.email@gmail.com>"

# ─── SERVER ───────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
